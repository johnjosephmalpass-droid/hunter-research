# HUNTER — environment template
# Copy this file to .env and fill in your own API keys.
# NEVER commit .env to version control.

# ─── Research engine (HUNTER core) ──────────────────────────────
ANTHROPIC_API_KEY=
# Web search provider (pick one; configure the matching key)
# SERPER_API_KEY=
# TAVILY_API_KEY=
# Optional: override the default database path
# HUNTER_DB_PATH=hunter.db

# ─── Quant data layer (quant.data.adapters) ─────────────────────
# All free or low-cost. Each can be skipped; adapters will explain how to enable.

# FRED macro data (FREE, instant)
#   Get key: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# SEC EDGAR (no key, but a User-Agent string is required by SEC policy;
# replace below with your own name + email)
EDGAR_USER_AGENT=Your Name your.email@example.com

# Polygon.io equity prices ($29/mo Starter; required for live trading)
#   Sign up: https://polygon.io
POLYGON_API_KEY=

# Tiingo news + EOD prices ($10/mo Starter)
#   Sign up: https://tiingo.com
TIINGO_API_KEY=

# OpenFDA FAERS (FREE, no key needed; optional key gives 120k req/day)
#   Get key: https://open.fda.gov/apis/authentication/
OPENFDA_API_KEY=

# ─── Brokerage execution (when ready to trade live) ─────────────
# Interactive Brokers — paper trading first, live later
# IBKR_USERNAME=
# IBKR_PAPER=true
